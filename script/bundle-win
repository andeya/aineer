#!/usr/bin/env bash
set -euo pipefail
# Aineer Windows bundle — cross-compile or native build + .exe with icon
# Usage: ./script/bundle-win [--release-channel dev|nightly|preview|stable]
#
# Prerequisites (cross-compile from macOS/Linux):
#   rustup target add x86_64-pc-windows-msvc   (or x86_64-pc-windows-gnu)
#   cargo install cargo-xwin                     (for MSVC target from non-Windows)
#
# Prerequisites (native Windows with Git Bash / MSYS2):
#   - Rust toolchain installed
#   - Inno Setup 6 (optional, for installer)
#
# Icon embedding:
#   On Windows the .ico is embedded via a .rc resource file compiled by windres or rc.exe.
#   The build.rs in crates/app handles this automatically when building on/for Windows.

CHANNEL="${2:-dev}"
echo "$CHANNEL" > RELEASE_CHANNEL

echo "=== Aineer Windows Bundle (channel=$CHANNEL) ==="

VERSION=$(grep '^version' Cargo.toml | head -1 | sed 's/.*"\(.*\)"/\1/')
TARGET="x86_64-pc-windows-msvc"

# ── Detect build method ──
if [[ "$(uname -s)" == *MINGW* ]] || [[ "$(uname -s)" == *MSYS* ]] || [[ "$(uname -s)" == *CYGWIN* ]] || [[ "$(uname -s)" == *Windows* ]]; then
    echo "▸ Native Windows build..."
    cargo build --release -p aineer
    BINARY="target/release/aineer.exe"
else
    echo "▸ Cross-compiling for ${TARGET}..."
    if command -v cargo-xwin &>/dev/null; then
        cargo xwin build --release -p aineer --target "$TARGET"
    else
        cargo build --release -p aineer --target "$TARGET"
    fi
    BINARY="target/${TARGET}/release/aineer.exe"
fi

if [ ! -f "$BINARY" ]; then
    echo "✗ Build failed — $BINARY not found"
    exit 1
fi

# ── Output directory ──
DIST_DIR="target/release/aineer-win"
rm -rf "$DIST_DIR"
mkdir -p "$DIST_DIR"

cp "$BINARY" "$DIST_DIR/Aineer.exe"
[ -f "assets/aineer.ico" ] && cp "assets/aineer.ico" "$DIST_DIR/"
cp RELEASE_CHANNEL "$DIST_DIR/"
cp LICENSE "$DIST_DIR/" 2>/dev/null || true

# ── Zip ──
ZIP_NAME="Aineer-${VERSION}-x86_64-windows.zip"
echo "▸ Creating ${ZIP_NAME}..."
(cd target/release && zip -r "$ZIP_NAME" aineer-win/)
echo "  ✓ target/release/${ZIP_NAME}"

# ── Inno Setup (optional) ──
if command -v iscc &>/dev/null || [ -f "/c/Program Files (x86)/Inno Setup 6/ISCC.exe" ]; then
    echo "▸ Creating Inno Setup installer..."
    ISCC="${ISCC:-iscc}"
    command -v iscc &>/dev/null || ISCC="/c/Program Files (x86)/Inno Setup 6/ISCC.exe"

    cat > "$DIST_DIR/setup.iss" << ISS
[Setup]
AppName=Aineer
AppVersion=${VERSION}
DefaultDirName={autopf}\\Aineer
DefaultGroupName=Aineer
OutputDir=..
OutputBaseFilename=Aineer-${VERSION}-setup
Compression=lzma2
SolidCompression=yes
SetupIconFile=aineer.ico
UninstallDisplayIcon={app}\\Aineer.exe

[Files]
Source: "Aineer.exe"; DestDir: "{app}"; Flags: ignoreversion
Source: "aineer.ico"; DestDir: "{app}"; Flags: ignoreversion

[Icons]
Name: "{group}\\Aineer"; Filename: "{app}\\Aineer.exe"; IconFilename: "{app}\\aineer.ico"
Name: "{autodesktop}\\Aineer"; Filename: "{app}\\Aineer.exe"; IconFilename: "{app}\\aineer.ico"
ISS
    "$ISCC" "$DIST_DIR/setup.iss" || echo "  ⚠ Inno Setup failed"
else
    echo "  ⚠ Inno Setup not found — skipping installer creation"
fi

echo ""
echo "✅ Windows build:"
echo "   Portable: $DIST_DIR/"
echo "   Zip:      target/release/${ZIP_NAME}"
