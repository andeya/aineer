#!/usr/bin/env bash
set -euo pipefail
# Aineer Linux bundle — tar.gz + .desktop + optional Flatpak
# Usage: ./script/bundle-linux [--release-channel dev|nightly|preview|stable]

CHANNEL="${2:-dev}"
echo "$CHANNEL" > RELEASE_CHANNEL

echo "=== Aineer Linux Bundle (channel=$CHANNEL) ==="

# ── Build ──
echo "▸ Building release binary..."
cargo build --release -p aineer

VERSION=$(grep '^version' Cargo.toml | head -1 | sed 's/.*"\(.*\)"/\1/')
ARCH=$(uname -m)
BINARY="target/release/aineer"

if [ ! -f "$BINARY" ]; then
    echo "✗ Build failed"
    exit 1
fi

# ── Stage directory ──
DIST="target/release/aineer-linux"
rm -rf "$DIST"
mkdir -p "$DIST/bin" "$DIST/share/applications" "$DIST/share/icons/hicolor"

cp "$BINARY" "$DIST/bin/aineer"
cp RELEASE_CHANNEL "$DIST/"
cp LICENSE "$DIST/" 2>/dev/null || true

# ── Icons ──
for sz in 48 256 512; do
    ICON_SRC="assets/icon-${sz}.png"
    if [ -f "$ICON_SRC" ]; then
        ICON_DIR="$DIST/share/icons/hicolor/${sz}x${sz}/apps"
        mkdir -p "$ICON_DIR"
        cp "$ICON_SRC" "$ICON_DIR/aineer.png"
        echo "  ✓ icon ${sz}x${sz}"
    fi
done
[ -f "assets/logo.svg" ] && {
    mkdir -p "$DIST/share/icons/hicolor/scalable/apps"
    cp "assets/logo.svg" "$DIST/share/icons/hicolor/scalable/apps/aineer.svg"
    echo "  ✓ icon scalable"
}

# ── .desktop file ──
cat > "$DIST/share/applications/aineer.desktop" << DESKTOP
[Desktop Entry]
Name=Aineer
Comment=The Agentic Development Environment
Exec=aineer %U
Icon=aineer
Terminal=false
Type=Application
Categories=Development;IDE;
StartupWMClass=aineer
MimeType=x-scheme-handler/aineer;
Keywords=AI;Development;Agent;Terminal;
DESKTOP
echo "  ✓ aineer.desktop"

# ── Install script ──
cat > "$DIST/install.sh" << 'INSTALL'
#!/usr/bin/env bash
set -euo pipefail
PREFIX="${1:-/usr/local}"
echo "Installing Aineer to ${PREFIX}..."
sudo install -Dm755 bin/aineer "${PREFIX}/bin/aineer"
sudo install -Dm644 share/applications/aineer.desktop "${PREFIX}/share/applications/aineer.desktop"
for icon in share/icons/hicolor/*/apps/aineer.*; do
    [ -f "$icon" ] && sudo install -Dm644 "$icon" "${PREFIX}/$icon"
done
echo "✓ Installed. Run: aineer"
INSTALL
chmod +x "$DIST/install.sh"
echo "  ✓ install.sh"

# ── Tarball ──
TARBALL="Aineer-${VERSION}-${ARCH}-linux.tar.gz"
echo "▸ Creating ${TARBALL}..."
tar czf "target/release/${TARBALL}" -C target/release aineer-linux
echo "  ✓ target/release/${TARBALL}"

echo ""
echo "✅ Linux build:"
echo "   Directory: ${DIST}/"
echo "   Tarball:   target/release/${TARBALL}"
echo "   Install:   cd ${DIST} && ./install.sh [PREFIX]"
